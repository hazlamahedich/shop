# Backend Environment Configuration
# Copy this file to .env and fill in your values

# Testing Mode (forces mock services, prevents API costs)

# Application Settings
APP_NAME=shop-backend
APP_VERSION=0.1.0
DEBUG=true

# Security (REQUIRED in production - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=dev-secret-key-for-testing-DO-NOT-USE-IN-PRODUCTION

# Database (PostgreSQL with pgvector)
# Using Docker PostgreSQL 17 on port 5433 (pgvector/pgvector:pg17 image)
DATABASE_URL=postgresql+asyncpg://developer:developer@127.0.0.1:5433/shop_dev
TEST_DATABASE_URL=postgresql+asyncpg://developer:developer@127.0.0.1:5433/shop_test

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
WEBHOOK_SECRET=webhook-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Shopify (configure during onboarding)
SHOPIFY_STORE_URL=
SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_API_VERSION=2024-01

# Facebook Messenger (configure during onboarding)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_API_VERSION=v19.0
FACEBOOK_REDIRECT_URI=https://your-domain.com/api/integrations/facebook/callback
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
# Legacy aliases (kept for compatibility)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_VERIFY_TOKEN=verify_token

# LLM Provider (configure during onboarding)
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-api03-lkBt5PIF1BqB1GDbqbkxJ_CgPmsmg85LkaXOSqSj3_7RjyeobohNXuwwnOVr06evt-nsxmnI9_2LVsYeAtiFQA-MUfclQAA
LLM_API_BASE=
LLM_MODEL=claude-sonnet-4-6

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-api03-lkBt5PIF1BqB1GDbqbkxJ_CgPmsmg85LkaXOSqSj3_7RjyeobohNXuwwnOVr06evt-nsxmnI9_2LVsYeAtiFQA-MUfclQAA
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=https://shopdevsherwingor.share.zrok.io,http://localhost:3000,http://localhost:5173,http://localhost:5174,https://volare-sun.myshopify.com,https://nil-soil-psychological-curtis.trycloudflare.com,https://portfolio-website-phi-brown.vercel.app

