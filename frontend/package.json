{
  "name": "shop-frontend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:with-typecheck": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:component": "vitest run tests/component",
    "test:component:ui": "vitest --ui tests/component",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:p0": "playwright test --grep \"\\[P0\\]\"",
    "test:e2e:p1": "playwright test --grep \"\\[P1\\]\"",
    "test:api": "playwright test tests/api",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "security": "npm audit --audit-level=high",
    "security:fix": "npm audit fix",
    "security:check": "snyk test",
    "outdated": "npm outdated",
    "build:widget": "vite build --config vite.widget.config.ts",
    "build:widget:size": "npm run build:widget && node scripts/check-bundle-size.js",
    "test:story-9-1": "npm run test:unit:9-1 && npm run test:e2e:9-1",
    "test:unit:9-1": "vitest run src/widget",
    "test:e2e:9-1": "playwright test tests/e2e/story-9-1-*.spec.ts",
    "test:a11y": "playwright test tests/e2e/story-9-1-accessibility-audit.spec.ts",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "perf": "npm run build && npm run lighthouse"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "canvas-confetti": "^1.9.4",
    "focus-trap-react": "^12.0.0",
    "framer-motion": "^12.38.0",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.1",
    "three": "^0.183.2",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@faker-js/faker": "^10.2.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^1.0.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "gzip-size": "^7.0.0",
    "jsdom": "^23.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.1.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
